---
import TabsItem from "./TabsItem.astro";
import type { TabsProps } from "./types";
type Props = TabsProps;
const { id, items, variant = "light" } = Astro.props;
---

<style>
  @import "./style.scss";
</style>
<ul
  class=`nav nav-tabs ${variant==="dark" ? "bg-primary" : ""}`
  id={id}
  role="tablist"
>
  {items.map((item) => <TabsItem {...item} />)}
</ul>
<div class="tab-content" id="tabsContent">
  <slot />
</div>
