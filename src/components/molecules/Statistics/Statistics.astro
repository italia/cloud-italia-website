---
import { DataContainer } from "@components/molecules/DataContainer";
import type { DataContainerProps } from "@components/molecules/DataContainer/types";

type Props = {
  items: DataContainerProps[];
};

const { items } = Astro.props;
---

<style>
  @import "./style.scss";
</style>

<div class="statistics-container">
  {items.map((item) => <DataContainer {...item} />)}
</div>
