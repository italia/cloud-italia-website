---
import type { StatisticsBoxProps } from "./types";

type Props = StatisticsBoxProps;

const { title, description } = Astro.props;
---

<article class="it-card it-card-height-full rounded border lightgrey-bg-a3">
  <div class="it-card-body">
    <p class="fw-semibold">{title}</p>
    <p class="h2">{description}</p>
  </div>
</article>
