---
import type { NavigationLinkProps } from "./types";
import ItArrowLeft from "@static/assets/ItArrowLeft.astro";
import ItArrowRight from "@static/assets/ItArrowRight.astro";

type Props = NavigationLinkProps;

const { title, linkTo, label, direction = "next" } = Astro.props;

const isPrevious = direction === "previous";
const justifyClass = isPrevious
  ? "justify-content-start"
  : "justify-content-end";
---

<div class="navigation-link d-flex flex-column gap-2">
  {label && <p class="fw-semibold fs-6 text-uppercase mb-0">{label}</p>}
  <a
    href={linkTo}
    class={`d-flex align-items-center gap-2 text-decoration-none fw-semibold text-primary ${justifyClass}`}
  >
    {
      isPrevious && (
        <ItArrowLeft size="sm" color="primary" class="align-middle" />
      )
    }
    <span>{title}</span>
    {
      !isPrevious && (
        <ItArrowRight size="sm" color="primary" class="align-middle" />
      )
    }
  </a>
</div>
