---
import { Chip } from "../../atoms/Chip";

type Props = {
  title: string;
  description: string;
  imageUrl: string;
  imageAlt?: string;
  linkTo: string;
  category?: string;
};

const {
  title,
  description,
  imageUrl,
  imageAlt = "",
  linkTo,
  category,
} = Astro.props;
---

<article
  class="it-card it-card-inline it-card-inline-mini it-card-image rounded-4 overflow-hidden"
>
  <div class="it-card-inline-content">
    <h3 class="it-card-title">
      <a href={linkTo}>{title}</a>
    </h3>
    <div class="it-card-body">
      <p class="it-card-text">
        {description}
      </p>
    </div>
    <footer class="it-card-related it-card-footer">
      {
        category && (
          <div class="it-card-taxonomy">
            <Chip visuallyHidden="Argomento" label={category} />
          </div>
        )
      }
    </footer>
  </div>
  <div class="it-card-image-wrapper">
    <div class="ratio ratio-1x1">
      <figure class="figure img-full">
        <img src={imageUrl} alt={imageAlt} />
      </figure>
    </div>
  </div>
</article>
