---
import { CardEditorialWithIcon } from "../../molecules/CardEditorialWithIcon";
import type { CardEditorialWithIconProps } from "../../molecules/CardEditorialWithIcon/types";

type Props = {
  cards: CardEditorialWithIconProps[];
};

const { cards } = Astro.props as Props;

if (!cards || cards.length === 0) {
  return null;
}
---

<div class="row align-item-center justify-content-between pt-4">
  {
    cards.map((card) => (
      <div class="col-12 col-md-6 mb-3 mb-md-4 col-lg-6">
        <CardEditorialWithIcon {...card} />
      </div>
    ))
  }
</div>
