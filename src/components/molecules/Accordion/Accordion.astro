---
import AccordionItem from "./AccordionItem.astro";
import type { AccordionProps } from "./types";
type Props = AccordionProps;
const { id, items, variant = "default" } = Astro.props;

const className =
  variant === "background-active" ? "accordion-background-active" : "";
---

<div class=`accordion ${className}` id={id}>
  {items.map((item) => <AccordionItem {...item} />)}
</div>
