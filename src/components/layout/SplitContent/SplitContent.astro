---
import { SectionContainer } from "@components/organisms/SectionContainer";
import type { SectionBackground, SplitContentProps } from "./types";

type Props = SplitContentProps;

const {
  leftColumns = 6,
  rightColumns = 6,
  alignItems = "center",
  background = "default",
  classSecondColumn = "",
} = Astro.props;

const backgroundColorClassNames: Record<SectionBackground, string> = {
  default: "it-section-bg-default dark",
  primary: "it-section-bg-primary",
  dark: "it-section-bg-dark",
  lighter: "it-section-bg-light dark",
};
---

<SectionContainer className={backgroundColorClassNames[background]}>
  <div class=`row justify-content-between align-items-${alignItems}`>
    <div class=`col-lg-${leftColumns} col-12`>
      <slot name="left" />
    </div>
    <div
      class=`col-lg-${rightColumns} col-12 mt-4 mt-lg-0 ${classSecondColumn}`
    >
      <slot name="right" />
    </div>
  </div>
  <slot />
</SectionContainer>
