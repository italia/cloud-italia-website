---
import { Footer } from "@components/organisms/Footer";
import type {
  FooterLinkProps,
  FooterLinkSupportingBrandProps,
  FooterLogoProps,
} from "@components/organisms/Footer/types";
import type { FooterFragmentType } from "@graphql/fragment/layout";
import { DatoBlockModel } from "@utils/cmsMapper";

import { linkResolver } from "@utils/linkResolver";

type Props = FooterFragmentType;

const {
  _allHeadingLocales,
  _allOrganizationsLocales,
  _allTopicTitleLocales,
  _allTopicLinkLocales,
  _allUtilityTitleLocales,
  _allUtilityLocales,
  _allSmallPrintLocales,
} = Astro.props;

const { lang } = Astro.locals;
const heading = _allHeadingLocales?.find((l) => l.locale === lang)?.value || "";
const organizations = _allOrganizationsLocales?.find(
  (l) => l.locale === lang,
)?.value;
const topicTitle =
  _allTopicTitleLocales?.find((l) => l.locale === lang)?.value || "";
const topicLink = _allTopicLinkLocales?.find((l) => l.locale === lang)?.value;
const utilityTitle =
  _allUtilityTitleLocales?.find((l) => l.locale === lang)?.value || "";
const utility = _allUtilityLocales?.find((l) => l.locale === lang)?.value;
const smallPrint = _allSmallPrintLocales?.find((l) => l.locale === lang)?.value;

const logos: FooterLogoProps[] =
  organizations?.map((org) => {
    return {
      mainLogo: org.mainLogo,
      brandLogo: org.brandLogo,
      label: org.label,
      linkTo: org.url,
    };
  }) || [];

const topicItems =
  topicLink?.map((link) => {
    return {
      label: link.label,
      visuallyHidden: "link",
      linkTo: linkResolver(link.linkTo.id, lang),
    };
  }) || [];

const socialUtilities: FooterLinkSupportingBrandProps[] =
  utility
    ?.filter((util) => util.componentName === "SupportingBrandRecord")
    .map((util) => ({
      label: util.label,
      ariaLabel: "link",
      icon: util.brandLogo,
      url: util.url,
    })) || [];

const linkUtilities: FooterLinkProps[] =
  utility
    ?.filter((util) => util.componentName === DatoBlockModel.ExternalLink)
    .map((util) => ({
      label: util.label,
      ariaLabel: "link",
      url: util.url,
      openInNewTab: true,
    })) || [];

const smallPrints: FooterLinkProps[] =
  smallPrint?.map((link) => {
    const isExternal = link.componentName === DatoBlockModel.ExternalLink;
    const url = isExternal ? link.url : linkResolver(link.linkTo?.id, lang);

    return {
      label: link.label,
      [isExternal ? "url" : "linkTo"]: url,
    };
  }) || [];
---

<Footer
  brand={{
    heading: heading,
    logos: logos,
  }}
  topics={{
    title: topicTitle,
    items: topicItems,
  }}
  utilities={[
    {
      title: utilityTitle,
      socialItems: socialUtilities,
      linkItems: linkUtilities,
    },
  ]}
  smallPrints={{
    links: smallPrints,
  }}
/>
