---
import { GenericList } from "@components/molecules/GenericList";
import type { GenericListItemProps } from "@components/molecules/GenericList/types";
import type { IconListBlockFragmentType } from "@graphql/commonFragments";

type Props = {
  block: IconListBlockFragmentType;
};

const { block } = Astro.props;

const items: GenericListItemProps[] =
  block.items?.items.map((item) => ({
    text: item.label,
    icon: item.icon,
  })) || [];
---

<GenericList
  label={block.title || undefined}
  items={items}
  size="small"
  bordered={false}
/>
