---
import StructuredTextAdapter from "@components/cms-adapters/datocms/StructuredTextAdapter.astro";
import { SectionContainer } from "@components/organisms/SectionContainer";
import type { StructuredTextFragmentType } from "@graphql/sectionFragments";

type Props = {
  block: StructuredTextFragmentType;
  isFontSerif?: boolean;
};

const { block, isFontSerif = false } = Astro.props;
---

<SectionContainer
  className=`col-12 col-lg-8 structured-text-container ${isFontSerif ? "font-serif-p" : ""} m-auto`
>
  <StructuredTextAdapter block={block} />
</SectionContainer>
