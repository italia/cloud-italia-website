---
import { OrderedList } from "@components/molecules/OrderedList";
import type { OrderedListFragmentType } from "@graphql/commonFragments";

type DatoRecord = OrderedListFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props as Props;
---

<OrderedList items={block.items} variant="default" />
