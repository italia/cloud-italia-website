---
import type {
  NewsTabFragmentType,
  StoryTabFragmentType,
} from "../../../graphql/commonFragments";
import type { NewsFeedFragmentType } from "../../../graphql/sectionFragments";
import { UpdateTabSection } from "../../organisms/UpdateTabSection";
import type { SiteLocale } from "../../../graphql/types";

type Props = {
  block: NewsFeedFragmentType;
  lang: SiteLocale;
};

const { block, lang } = Astro.props;

console.log("[PROPS] lang", lang);

const mappingCriteria = (tab: NewsTabFragmentType | StoryTabFragmentType) => {
  switch (tab.componentName) {
    case "NewsTabRecord":
      return {
        componentName: "NewsTabRecord",
        title: tab.title,
        news: tab.news.map((n) => ({
          title: n.title,
          description: n.paragraph,
          image: n.image,
          linkTo: n.link,
          category: n.category,
          dateTime: n.dateOfPublication,
          action: new URL(n.link).host,
        })),
      };

    case "StoryTabRecord":
      return {
        componentName: "StoryTabRecord",
        title: tab.title,
        news: tab.news.map((n) => ({
          title: n.title,
          image: n.image,
          linkTo: `/${n.slug}`,
          category: n.category,
          dateTime: n.dateOfPublication,
        })),
      };
  }
};
---

<UpdateTabSection
  title={block.title}
  paragraph={block.paragraph}
  tabs={block.tabs.map(mappingCriteria)}
/>
