---
import type { VariantAccordionProps } from "@components/molecules/Accordion/types";
import { FAQSection } from "@components/organisms/FAQSection";
import type { FaqSectionRecordFragmentType } from "@graphql/fragment/sectionFragments";

type Props = {
  block: FaqSectionRecordFragmentType;
};

const { block } = Astro.props;
---

<FAQSection
  title={block.title}
  accordion={{
    ...block.accordion,
    variant: block.accordion.variant as VariantAccordionProps,
  }}
/>
