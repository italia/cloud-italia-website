---
import AccordionAdapter from "@components/cms-adapters/datocms/AccordionAdapter.astro";
import TextContainerAdapter from "@components/cms-adapters/datocms/TextContainerAdapter.astro";
import { SplitContent } from "@components/layout/SplitContent";
import type { TextAndAccordionFragmentType } from "@graphql/fragment/sectionFragments";

type Props = {
  block: TextAndAccordionFragmentType;
};

const { block } = Astro.props;
---

<SplitContent rightColumns={5} leftColumns={5} alignItems="top">
  <Fragment slot="left">
    <TextContainerAdapter block={block.text} variant="light" />
  </Fragment>
  <Fragment slot="right">
    <AccordionAdapter block={block.accordion} />
  </Fragment>
</SplitContent>
