---
import { TextContainer } from "@components/molecules/TextContainer";
import type { TextContainerVariant } from "@components/molecules/TextContainer/types";
import type { TextBlockFragmentType } from "@graphql/fragment/commonFragments";
import { DatoBlockModel } from "@utils/cmsMapper";
import { linkResolver } from "@utils/linkResolver";

type Props = {
  block: TextBlockFragmentType;
  variant: TextContainerVariant;
};

const { block, variant } = Astro.props;
const { lang } = Astro.locals;

const getCtaFields = () => {
  const cta = block.cta;

  if (!cta) return { labelButton: undefined, linkTo: undefined };

  switch (cta.componentName) {
    case DatoBlockModel.ExternalLink:
      return {
        labelButton: cta.label,
        linkTo: cta.url,
      };
    case DatoBlockModel.InternalLink:
      return {
        labelButton: cta.label,
        linkTo: linkResolver(cta.linkTo?.id, lang),
      };
    default:
      return {
        labelButton: undefined,
        linkTo: undefined,
      };
  }
};

const { labelButton, linkTo } = getCtaFields();
---

<TextContainer
  title={block.title}
  paragraph={block.paragraph}
  variant={variant}
  labelButton={labelButton}
  linkTo={linkTo}
/>
