---
import { NewsFeed } from "@components/organisms/NewsFeed";
import type { NewsFeedFragmentType } from "@graphql/fragment/sectionFragments";
import { linkResolver } from "@utils/linkResolver";

type Props = {
  block: NewsFeedFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;

const buttonLink =
  block.cta?.linkTo?.id !== undefined
    ? linkResolver(block.cta.linkTo.id, lang)
    : undefined;
const buttonLabel = block.cta?.label;
---

<NewsFeed
  id={block.id}
  title={block.title}
  paragraph={block.paragraph}
  labelButton={buttonLabel}
  linkTo={buttonLink}
  tabs={block.tabs.map((tab) => {
    switch (tab.componentName) {
      case "NewsTabRecord":
        return {
          componentName: "CardEditorialNews",
          title: tab.title,
          news: tab.news.map((n) => ({
            title: n.title,
            description: n.paragraph,
            image: n.image,
            linkTo: n.link,
            category: n.topic.label,
            dateTime: n.dateOfPublication,
            action: new URL(n.link).host,
          })),
        };

      case "StoryTabRecord":
        return {
          componentName: "CardEditorialInlineMini",
          title: tab.title,
          news: tab.news.map((n) => ({
            title: n.title,
            image: n.image,
            linkTo: linkResolver(n.id, lang),
            category: n.topic.label,
            dateTime: n.dateOfPublication,
          })),
        };
    }
  })}
/>
