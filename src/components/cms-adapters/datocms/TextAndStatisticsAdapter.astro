---
import StatisticAdapter from "@components/cms-adapters/datocms/StatisticAdapter.astro";
import TextContainerAdapter from "@components/cms-adapters/datocms/TextContainerAdapter.astro";
import type { SectionBackground } from "@components/layout/SplitContent/types";
import { TextAndStatistics } from "@components/organisms/TextAndStatistics";
import type { TextAndStatisticsFragmentType } from "@graphql/fragment/sectionFragments";

type Props = {
  block: TextAndStatisticsFragmentType;
};

const { block } = Astro.props;

const variantTextContainer =
  block.backgroundColor === "dark" ? "dark" : "light";
---

<TextAndStatistics background={block.backgroundColor as SectionBackground}>
  <TextContainerAdapter
    slot="text"
    block={block.text}
    variant={variantTextContainer}
  />
  <StatisticAdapter
    slot="statistics"
    block={block.statistics}
    variant={variantTextContainer}
  />
</TextAndStatistics>
