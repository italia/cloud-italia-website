---
import type { HeaderFragmentType } from "../../../graphql/sectionFragments";
import type { SiteLocale } from "../../../graphql/types";
import { createMenu } from "../../../utils/createMenuHelper";
import { Header } from "../../organisms/Header";

type Props = HeaderFragmentType & {
  currentUrl: string;
  currentLocale: SiteLocale;
};

const {
  tagline,
  organization,
  siteName,
  navigationBar,
  currentUrl,
  currentLocale,
} = Astro.props;

const menuItems = createMenu(navigationBar, currentUrl, currentLocale);
---

<Header
  brandTagLine={organization}
  brandTitle={siteName}
  slimContent={tagline}
  menuItems={menuItems}
/>
