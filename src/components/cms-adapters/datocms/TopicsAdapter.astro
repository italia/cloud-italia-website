---
import { Topics } from "@components/molecules/Topics";
import type { TopicsBlockFragmentType } from "@graphql/fragment/commonFragments";

type DatoRecord = TopicsBlockFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props;
const { lang } = Astro.locals;
---

<Topics
  title={block.title || undefined}
  topics={block.topics.map(
    (topic) =>
      topic._allLabelLocales?.find((l) => l.locale === lang)?.value || "",
  )}
/>
