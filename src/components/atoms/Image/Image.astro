---
import type { ImageProps } from "./types";
import { Image as ImageAstro } from "astro:assets";
type Props = ImageProps;

const { url, alt = "", title = "", width, height } = Astro.props;
if (!width || !height) {
  return null;
}
const targetWidths = [480, 720, 1024, width];
const responsiveWidths = targetWidths.filter((w) => w <= width);
---

<ImageAstro
  src={url}
  title={title}
  alt={alt || ""}
  widths={responsiveWidths}
  width={width}
  height={height}
  loading="lazy"
/>
