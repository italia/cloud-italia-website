---
import type { HeroProps } from "./types";
import { Image } from "@components/atoms/Image";

type Props = HeroProps;

const {
  title,
  paragraph,
  image,
  showBreadcrumb = false,
  variant = "default",
} = Astro.props;
const sizeClass = variant === "small" ? "small-size" : "default-size";
---

<style>
  @import "./style.scss";
</style>

<section class={`it-hero-wrapper it-primary ${sizeClass}`}>
  {
    image && (
      <div class="img-responsive-wrapper">
        <div class="img-responsive">
          <div class="img-wrapper">
            <Image {...image} />
          </div>
        </div>
      </div>
    )
  }

  <div class="container">
    <div class="row">
      <div class="col-12">
        <div class="it-hero-text-wrapper">
          {showBreadcrumb && <slot name="breadcrumb" />}
          <h1>{title}</h1>
          {
            paragraph && (
              <p class="d-none d-lg-block font-sans-serif">{paragraph}</p>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
