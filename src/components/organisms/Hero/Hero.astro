---
import type { SectionBackground } from "@components/layout/SplitContent/types";
import HeroCompactImage from "./HeroCompactImage.astro";
import HeroDefault from "./HeroDefault.astro";
import HeroFullHeightImage from "./HeroFullHeightImage.astro";
import type { HeroProps } from "./types";

type Props = HeroProps;

const {
  title,
  paragraph,
  image,
  imageMobile,
  showBreadcrumb = false,
  variant = "default",
  backgroundColor = "default",
} = Astro.props;

const backgroundColorClassNames: Record<SectionBackground, string> = {
  default: "it-hero-bg-default dark",
  primary: "it-hero-bg-primary",
  dark: "it-hero-bg-dark",
  lighter: "it-hero-bg-light dark",
};

const classBackground =
  image && (variant === "default" || variant === "small")
    ? backgroundColorClassNames["primary"]
    : backgroundColorClassNames[backgroundColor];
---

<style>
  @import "./style.scss";
</style>

{
  (variant === "default" || variant === "small") && (
    <HeroDefault
      title={title}
      paragraph={paragraph}
      image={image}
      imageMobile={imageMobile}
      variant={variant}
      showBreadcrumb={showBreadcrumb}
      bgClass={classBackground}
    >
      <slot name="breadcrumb" slot="breadcrumb" />
    </HeroDefault>
  )
}

{
  variant === "xsmall-compact" && (
    <HeroCompactImage
      title={title}
      paragraph={paragraph}
      image={image}
      showBreadcrumb={showBreadcrumb}
      bgClass={classBackground}
    >
      <slot name="breadcrumb" slot="breadcrumb" />
    </HeroCompactImage>
  )
}

{
  variant === "xsmall-full" && (
    <HeroFullHeightImage
      title={title}
      paragraph={paragraph}
      image={image}
      showBreadcrumb={showBreadcrumb}
      bgClass={classBackground}
    >
      <slot name="breadcrumb" slot="breadcrumb" />
    </HeroFullHeightImage>
  )
}
