---
import HeaderCentral from "./HeaderCentral.astro";
import HeaderSlim from "./HeaderSlim.astro";
import type { HeaderProps } from "./types";

type Props = HeaderProps;

const { slimContent, brandTitle, brandTagLine, menuItems } = Astro.props;
---

<header class="it-header-wrapper shadow-sm">
  <HeaderSlim slimContent={slimContent} linkTo={"#"} />
  <HeaderCentral
    brandTitle={brandTitle}
    brandTagLine={brandTagLine}
    menuItems={menuItems}
    linkBackHome="#"
  />
</header>
