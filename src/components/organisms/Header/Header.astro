---
import HeaderCentral from "./HeaderCentral.astro";
import HeaderSlim from "./HeaderSlim.astro";
import type { HeaderProps } from "./types";

type Props = HeaderProps;

const {
  slimContent,
  locales,
  brandTitle,
  brandTagLine,
  menuItems,
  linkBackHome,
  logo,
  search,
  ariaLabelLinkLogo,
  ariaLabelLanguageSelector,
} = Astro.props;
---

<header class="it-header-wrapper shadow-sm">
  <HeaderSlim
    slimContent={slimContent}
    linkBackHome={linkBackHome}
    locales={locales}
    ariaLabelLanguageSelector={ariaLabelLanguageSelector}
  />
  <HeaderCentral
    search={search}
    brandTitle={brandTitle}
    brandTagLine={brandTagLine}
    menuItems={menuItems}
    linkBackHome={linkBackHome}
    logo={logo}
    ariaLabelLinkLogo={ariaLabelLinkLogo}
  />
</header>
