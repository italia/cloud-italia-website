---
import { SplitContent } from "@components/layout/SplitContent";
import type { TextAndImageProps } from "./types";

type Props = TextAndImageProps;

const { background, variant } = Astro.props;
const columnLeftSize = variant === "variant-2" ? 4 : 6;
const columnRightSize = variant === "variant-2" ? 8 : 5;

const alignItems = variant === "variant-2" ? "top" : "center";
---

<SplitContent
  leftColumns={columnLeftSize}
  rightColumns={columnRightSize}
  alignItems={alignItems}
  background={background}
>
  <slot name="text" slot="left" />
  <slot name="image" slot="right" />
  <slot name="additionalContent" />
</SplitContent>
