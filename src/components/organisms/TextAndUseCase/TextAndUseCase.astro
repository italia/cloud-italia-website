---
import TextContainer from "../../molecules/TextContainer/TextContainer.astro";
import { UseCaseCard } from "../../molecules/UseCaseCard";
import type { UseCaseCardProps } from "../../molecules/UseCaseCard/types";
import { SectionContainer } from "../SectionContainer";

type Props = {
  title: string;
  paragraph: string;
  labelButton: string;
  labelUseCases: string;
  useCases: UseCaseCardProps[];
};
const { title, paragraph, labelButton, labelUseCases, useCases } = Astro.props;
---

<style>
  @import "./style.scss";
</style>
<SectionContainer>
  <div class="row align-items-top justify-content-between">
    <div class="col-lg-5 col-12">
      <TextContainer
        title={title}
        paragraph={paragraph}
        labelButton={labelButton}
      />
    </div>
    <div class="col-lg-6 col-12">
      <p class="fw-semibold fs-6 text-uppercase">{labelUseCases}</p>
      <div class="usecase-container">
        {useCases.map((useCase) => <UseCaseCard {...useCase} />)}
      </div>
    </div>
  </div>
</SectionContainer>
