---
import { SplitContent } from "@components/layout/SplitContent";
import type { SectionBackground } from "@components/layout/SplitContent/types";

type Props = {
  background: SectionBackground;
};

const { background } = Astro.props;
---

<SplitContent
  rightColumns={6}
  leftColumns={5}
  alignItems="top"
  background={background}
>
  <slot name="text" slot="left" />
  <slot name="useCases" slot="right" />
</SplitContent>
