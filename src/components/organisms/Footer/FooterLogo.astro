---
import type { FooterLogoProps } from "./types";

type Props = FooterLogoProps;

const { icon, label, linkTo } = Astro.props;
---

<a href={linkTo} target="_blank" rel="noreferrer" class="d-block">
  <svg class="icon icon-white me-3" aria-hidden="true"
    ><use href=`/bsi-svg/sprites.svg#${icon}`></use></svg
  >
  {label}
</a>
