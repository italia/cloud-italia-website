---
import { CardPresentationBanner } from "../../molecules/CardPresentationBanner";
import type { CardPresentationBannerProps } from "../../molecules/CardPresentationBanner/types";
import TextContainer from "../../molecules/TextContainer/TextContainer.astro";
import { SectionContainer } from "../SectionContainer";

type Props = {
  title: string;
  paragraph: string;
  channels: CardPresentationBannerProps[];
};
const { title, paragraph, channels } = Astro.props;
---

<SectionContainer>
  <div class="row align-items-top justify-content-between">
    <div class="col-lg-5 col-12">
      <TextContainer title={title} paragraph={paragraph} />
    </div>
  </div>
  <div class="row pt-5">
    {
      channels.map((item) => (
        <div class="col-12 col-md-6 mb-3 mb-md-4 col-lg-4">
          <CardPresentationBanner {...item} />
        </div>
      ))
    }
  </div>
</SectionContainer>
