---
import { UseCaseCard } from "@components/molecules/UseCaseCard";
import type { UseCaseCardProps } from "@components/molecules/UseCaseCard/types";
import { SectionContainer } from "@components/organisms/SectionContainer";

type Props = {
  useCases: UseCaseCardProps[];
};

const { useCases } = Astro.props;
---

<SectionContainer>
  {
    useCases.map((item) => (
      <div class="row pt  -5">
        <div class="col-12 mb-3 mb-md-4">
          <UseCaseCard {...item} variant="big" />
        </div>
      </div>
    ))
  }
</SectionContainer>
