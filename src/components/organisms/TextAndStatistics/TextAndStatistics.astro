---
import { SplitContent } from "@components/layout/SplitContent";
import { Statistics } from "@components/molecules/Statistics";
import { TextContainer } from "@components/molecules/TextContainer";
import type { TextAndStatisticsProps } from "@components/organisms/TextAndStatistics/types";

type Props = TextAndStatisticsProps;

const { title, paragraph, labelButton, dataStatistics } = Astro.props;
---

<SplitContent rightColumns={5} background="dark">
  <TextContainer
    slot="left"
    title={title}
    paragraph={paragraph}
    labelButton={labelButton}
    variant="dark"
  />
  <Statistics slot="right" items={dataStatistics} />
</SplitContent>
