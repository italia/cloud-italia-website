---
import SidebarLayoutAdapter from "@components/cms-adapters/datocms/SidebarLayoutAdapter.astro";
import type {
  SidebarFragmentType,
  TagFragmentType,
} from "@graphql/commonFragments";
import { ArticleSeoQuery } from "@graphql/query/article";
import type { SeoFieldFragmentType } from "@graphql/seoFragments";
import type { ArticleContentFragmentType } from "@graphql/templateFragments";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { type JsonLdPageData } from "@utils/JsonLD/seoJsonLd";
import { linkResolver } from "@utils/linkResolver";
import { removeLang } from "@utils/pathHelper";
import { AllArticlesQuery, SidebarQuery } from "@utils/query";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      article: string;
      lang: SiteLocale;
    };
    props: {
      seoMeta: TagFragmentType[];
      seo: SeoFieldFragmentType | null;
      content: ArticleContentFragmentType;
      id: string;
      sidebar: SidebarFragmentType;
      publishedAt: string;
      updatedAt: string;
    };
  };

  const response = await executeQuery(AllArticlesQuery);

  const pathsPromises =
    response.allArticles?.flatMap((page) =>
      page.locales.map(async (lang) => {
        const seoRes = await executeQuery(ArticleSeoQuery, {
          variables: { id: page.id, locale: lang },
        });

        const { sidebarForArticle } = await executeQuery(SidebarQuery, {
          variables: { locale: lang },
        });

        const fullPath = linkResolver(page.id, lang);

        const slug = removeLang(fullPath, lang);

        return {
          params: {
            article: slug,
            lang: lang,
          },
          props: {
            seoMeta: seoRes.article?.metaTags || [],
            seo: seoRes.article?.seo ?? null,
            id: page.id,
            sidebar: sidebarForArticle,
            content: page.allContentLocales?.find(
              (contentLocale) => contentLocale.locale === lang,
            )?.value,
            publishedAt: page.publishedAt,
            updatedAt: seoRes.article?.updatedAt || page.updatedAt,
          },
        };
      }),
    ) || [];

  const paths = await Promise.all(pathsPromises);

  return paths.filter((path): path is PathItem => !!path.params.lang);
}

const { seo, seoMeta, content, id, sidebar, publishedAt, updatedAt } =
  Astro.props;
const { lang } = Astro.params;

Astro.locals.lang = lang;
Astro.locals.recordId = id;
const jsonLd: JsonLdPageData = {
  pageType: ["content"],
  seo: seo || undefined,
  articleType: "TechArticle",
  publishedAt,
  updatedAt,
};
---

<Layout pageSeo={seoMeta} datePublished={publishedAt} jsonLd={jsonLd}>
  <SidebarLayoutAdapter sidebar={sidebar} content={content} />
</Layout>
