---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { TagFragmentType } from "@graphql/commonFragments";
import {
  AllInsightsContentQuery,
  InsightSeoQuery,
} from "@graphql/query/insight";
import type { SeoFieldFragmentType } from "@graphql/seoFragments";
import type { InsightContentFragmentType } from "@graphql/templateFragments";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { extractFaqItems, type JsonLdPageData } from "@utils/JsonLD/seoJsonLd";
import { linkResolver } from "@utils/linkResolver";
import { removeLang } from "@utils/pathHelper";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      insight: string;
      lang: SiteLocale;
    };
    props: {
      seoMeta: TagFragmentType[];
      seo: SeoFieldFragmentType | null;
      content: InsightContentFragmentType[];
      id: string;
      publishedAt: string;
      updatedAt: string;
    };
  };

  const response = await executeQuery(AllInsightsContentQuery);

  const pathsPromises =
    response.allInsights?.flatMap((page) =>
      page.locales.map(async (lang) => {
        const seoRes = await executeQuery(InsightSeoQuery, {
          variables: { id: page.id, locale: lang },
        });

        const fullPath = linkResolver(page.id, lang);

        const slug = removeLang(fullPath, lang);

        return {
          params: {
            insight: slug,
            lang: lang,
          },
          props: {
            seoMeta: seoRes.insight?.metaTags || [],
            seo: seoRes.insight?.seo ?? null,
            id: page.id,
            publishedAt: page.publishedAt,
            updatedAt: seoRes.insight?.updatedAt || page.updatedAt,
            content: page.allContentLocales?.find(
              (contentLocale) => contentLocale.locale === lang,
            )?.value,
          },
        };
      }),
    ) || [];

  const paths = await Promise.all(pathsPromises);

  return paths.filter((path): path is PathItem => !!path.params.lang);
}

const { id, content, seo, seoMeta, publishedAt, updatedAt } = Astro.props;
const { lang } = Astro.params;

Astro.locals.lang = lang;
Astro.locals.recordId = id;

const jsonLd: JsonLdPageData = {
  pageType: ["content"],
  seo: seo || undefined,
  articleType: "Article",
  publishedAt,
  updatedAt,
  faq: extractFaqItems(content ?? []),
};
---

<Layout pageSeo={seoMeta} datePublished={publishedAt} jsonLd={jsonLd}>
  <PageAdapter content={content} isFontSerif={true} />
</Layout>
