---
import ArticleAdapter from "@components/cms-adapters/datocms/ArticleAdapter.astro";
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { TagFragmentType } from "@graphql/commonFragments";
import type { InsightContentFragmentType } from "@graphql/templateFragments";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { buildFullPathInsights } from "@utils/pathHelper";
import { AllInsightsQuery } from "@utils/query";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      insight: string;
      lang: SiteLocale;
    };
    props: {
      seo: TagFragmentType[];
      content: InsightContentFragmentType[];
      id: string;
    };
  };

  const response = await executeQuery(AllInsightsQuery);
  if (!response.allInsights) {
    return [];
  }

  return response.allInsights
    ?.flatMap((insight) =>
      insight.locales.map((lang) => ({
        params: {
          insight: buildFullPathInsights(insight, lang).fullPath,
          lang: lang,
        },
        props: {
          id: insight.id,
          content: insight.allContentLocales?.find(
            (contentLocale) => contentLocale.locale === lang,
          )?.value,
        },
      })),
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang } = Astro.params;
const { seo, content, id } = Astro.props;

Astro.locals.recordId = id;
---

<Layout pageSeo={seo}>
  <PageAdapter content={content} />
</Layout>
