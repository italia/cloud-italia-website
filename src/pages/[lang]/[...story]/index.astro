---
import ArticleAdapter from "@components/cms-adapters/datocms/ArticleAdapter.astro";
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { TagFragmentType } from "@graphql/commonFragments";
import type {
  InsightContentFragmentType,
  StoryContentFragmentType,
} from "@graphql/templateFragments";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { resolveRoutePath } from "@utils/pathHelper";
import { AllStoryItemsQuery } from "@utils/query";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      story: string;
      lang: SiteLocale;
    };
    props: {
      seo: TagFragmentType[];
      content: StoryContentFragmentType[];
      id: string;
    };
  };

  const response = await executeQuery(AllStoryItemsQuery);
  if (!response.allStoryItems) {
    return [];
  }

  return response.allStoryItems
    ?.flatMap((story) =>
      story.locales.map((lang) => ({
        params: {
          story: resolveRoutePath(story, lang).fullPath,
          lang: lang,
        },
        props: {
          id: story.id,
          content: story.allContentLocales?.find(
            (contentLocale) => contentLocale.locale === lang,
          )?.value,
        },
      })),
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang } = Astro.params;
const { seo, content, id } = Astro.props;

Astro.locals.recordId = id;
---

<Layout pageSeo={seo}>
  <PageAdapter content={content} />
</Layout>
