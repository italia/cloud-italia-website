---
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";

import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { TagFragmentType } from "@graphql/commonFragments";
import { AllPagesContentQuery, PageSeoQuery } from "@graphql/query/page";
import type { PageContentFragmentType } from "@graphql/templateFragments";
import { linkResolver } from "@utils/linkResolver";
import { removeLang } from "@utils/pathHelper";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      slug: string;
      lang: SiteLocale;
    };
    props: {
      seo: TagFragmentType[];
      content: PageContentFragmentType[];
      publishedAt: string;
      id: string;
    };
  };

  const response = await executeQuery(AllPagesContentQuery);

  const pathsPromises =
    response.allPages?.flatMap((page) =>
      page.locales.map(async (lang) => {
        const seoRes = await executeQuery(PageSeoQuery, {
          variables: { id: page.id, locale: lang },
        });

        const fullPath = linkResolver(page.id, lang);

        const slug = removeLang(fullPath, lang);

        return {
          params: {
            slug: slug,
            lang: lang,
          },
          props: {
            seo: seoRes.page?.seo || [],
            id: page.id,
            publishedAt: page.publishedAt,
            content: page.allContentLocales?.find(
              (contentLocale) => contentLocale.locale === lang,
            )?.value,
          },
        };
      }),
    ) || [];

  const paths = await Promise.all(pathsPromises);

  return paths.filter((path): path is PathItem => !!path.params.lang);
}

const { id, content, seo, publishedAt } = Astro.props;

Astro.locals.recordId = id;
---

<Layout pageSeo={seo} datePublished={publishedAt}>
  <PageAdapter content={content} />
</Layout>
