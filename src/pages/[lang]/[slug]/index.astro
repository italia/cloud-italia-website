---
import Layout from "../../../layouts/Layout.astro";
import { executeQuery } from "../../../lib/datocms";
import { AllPagesSlugQuery, PageBySlugQuery } from "../../../utils/query";
import type {
  SettingsChartRecord,
  SiteLocale,
  SettingsKpiRecord,
} from "../../../graphql/types";
import { Chart } from "../../../components/charts/Chart";
import Loader from "../../../components/Loader.astro";
import { Kpi } from "../../../components/charts/Kpi";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      slug: string;
      lang: SiteLocale;
    };
  };

  const slugsResponse = await executeQuery(AllPagesSlugQuery);

  return slugsResponse.allPages
    .flatMap(
      (slug) =>
        slug.allSlugLocales?.map((slugLocale) => ({
          params: {
            slug: slugLocale.value,
            lang: slugLocale.locale,
          },
        })) ?? [],
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang, slug } = Astro.params;

const response = await executeQuery(PageBySlugQuery, {
  variables: { slug: slug, locale: lang },
});

const page = response.page;
const chart = page?.chart as SettingsChartRecord | undefined;
const kpi = page?.kpi as SettingsKpiRecord | undefined;
---

<Layout locale={lang} pageSeo={page?.seo}>
  <div class="mx-4">
    <h1>{page?.title}</h1>
    {kpi && <Kpi data={kpi} />}
    {
      chart && (
        <Chart client:only="react" data={chart}>
          <div slot="fallback">
            <Loader />
          </div>
        </Chart>
      )
    }
  </div>
</Layout>
