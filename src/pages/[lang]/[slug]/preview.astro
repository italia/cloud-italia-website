---
import type { TitleMetaLinkTag } from "@datocms/astro";
import Layout from "../../../layouts/Layout.astro";
import { executeQuery } from "../../../lib/datocms";
import { PageBySlugQuery } from "../../../utils/query";
import type { SiteLocale } from "../../../graphql/types";
import { isDraftModeEnabled } from "../../../lib/draftMode";
import DraftModeQueryListener from "../../../components/DraftModeQueryListener.astro";
import type { FieldDataType } from "dataviz-components";
import { Chart } from "../../../components/charts/Chart";
import Loader from "../../../components/Loader.astro";

export const prerender = false;

const draftModeEnabled = isDraftModeEnabled(Astro.cookies);
if (!draftModeEnabled) {
  return Astro.redirect("/");
}

const { lang, slug } = Astro.params;

const response = await executeQuery(PageBySlugQuery, {
  variables: { slug: slug!, locale: lang as SiteLocale },
  includeDrafts: true,
});

const page = response.page;
const chartData = page?.chartData as FieldDataType | undefined;
const redirectUrl =
  typeof lang === "string" && typeof slug === "string"
    ? `/${lang}/${slug}`
    : "/";
---

<Layout
  redirectUrl={redirectUrl}
  locale={lang!}
  pageSeo={page?.seo as TitleMetaLinkTag[]}
>
  <h1>{page?.title}</h1>
  {
    chartData?.data?.length && (
      <Chart client:only="react" data={chartData}>
        <div slot="fallback">
          <Loader />
        </div>
      </Chart>
    )
  }
</Layout>
<DraftModeQueryListener
  query={PageBySlugQuery}
  variables={{ slug: slug!, locale: lang as SiteLocale }}
/>
