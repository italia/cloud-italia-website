---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import { HomepageQuery } from "@graphql/query/homepage";
import { LocalesQuery } from "@graphql/query/settings";

import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";

export async function getStaticPaths() {
  const {
    site: { locales },
  } = await executeQuery(LocalesQuery);
  return locales.map((lang) => ({
    params: {
      lang,
    },
  }));
}

const { lang } = Astro.params;
Astro.locals.lang = lang;

const { homepage } = await executeQuery(HomepageQuery, {
  variables: { locale: lang },
});

if (!homepage) return;

const content = homepage.content;
Astro.locals.recordId = homepage.id;
---

<Layout pageSeo={homepage.metaTags} datePublished={homepage.publishedAt}>
  <PageAdapter content={content} />
</Layout>
